# GEMINI_API_KEY: Required for Gemini AI API calls.
# In local development, place it in your .env file.
# In Docker/Hugging Face Spaces, provide it as a secret or environment variable.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# PORT: Local development port for the Express + Vite server.
# Change this if 3000 is already occupied on your machine.
PORT="3005"

# HOST: Optional bind address for the local server.
HOST="0.0.0.0"

# APP_URL: The URL where this applet is hosted.
# Optional. Reserved for hosted deployments that need a known external base URL.
APP_URL="MY_APP_URL"
